meta {
  name: NDF (Detail)
  type: http
  seq: 2
}

get {
  url: {{base}}/ndf/{{ndfId}}
  body: none
  auth: bearer
}

headers {
  ~authorization: {{token}}
}

auth:bearer {
  token: {{jwtToken}}
}

docs {
  Détail d'une note de frais, dépenses incluses (tableau `depenses`).
  La variable `ndfId` est positionnée automatiquement par « NDF (Creer) ».
}
