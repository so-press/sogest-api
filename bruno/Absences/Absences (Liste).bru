meta {
  name: Absences (Liste)
  type: http
  seq: 1
}

get {
  url: {{base}}/absences
  body: none
  auth: bearer
}

params:query {
  ~sort: date
  ~order: desc
  ~type: conge
  ~from: 2021-08-01
  ~to: 2021-09-30
  ~year: 2021
  ~month: 8
  ~page: 1
  ~limit: 50
}

headers {
  ~authorization: {{token}}
}

auth:bearer {
  token: {{jwtToken}}
}
